# ============================================================
# AI Document Generator — пример конфигурации
# Скопируй в .env и заполни своими значениями
# ============================================================

# ------ OpenAI / ProxyAPI -----------------------------------
PROXYAPI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PROXYAPI_BASE_URL=https://api.proxyapi.ru/openai/v1
OPENAI_MODEL=gpt-4o-mini

# ------ Приложение ------------------------------------------
APP_NAME=AI Document Generator
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ------ База данных и файлы ---------------------------------
DATABASE_URL=sqlite:///./data/documents.db
REPORTS_DIR=./reports
MAX_TEXT_LEN=10000

# ------ Генерация изображений (опционально) -------------------------
IMAGE_GENERATION_ENABLED=false

# Бэкенд: openai | gigachat | yandex
IMAGE_BACKEND=openai

# --- OpenAI DALL-E 3 (через ProxyAPI, тот же ключ что выше) ----------
# Ключ берётся из PROXYAPI_API_KEY — отдельно указывать не нужно

# --- GigaChat text2image ---------------------------------------------
# Получи ключ: https://developers.sber.ru/studio/
# Credentials = base64(client_id:client_secret)
GIGACHAT_CREDENTIALS=
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# --- YandexART --------------------------------------------------------
# Инструкция: https://yandex.cloud/ru/docs/foundation-models/image-generation/
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
TELEGRAM_BOT_TOKEN=
# Прокси Karing (SOCKS5) — нужен в России для доступа к Telegram API
TELEGRAM_PROXY=socks5://127.0.0.1:1080
